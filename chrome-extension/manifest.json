{
  "manifest_version": 3,
  "name": "Salesflow Workflows Token Grabber",
  "version": "1.1.0",
  "description": "Grab Firebase refresh token from Salesflow One (GoHighLevel) for CLI workflow building",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://app.salesflow.one/*",
    "https://app.gohighlevel.com/*",
    "https://*.leadconnectorhq.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
